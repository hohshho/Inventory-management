FROM node:20-alpine AS base
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN corepack enable && corepack prepare pnpm@10.0.0 --activate

FROM base AS deps
WORKDIR /app
COPY . .
RUN pnpm install --frozen-lockfile

FROM base AS builder
WORKDIR /app
COPY --from=deps /app /app

ARG NEXT_PUBLIC_APP_ENV=development
ARG NEXT_PUBLIC_API_BASE_URL
ARG NEXT_PUBLIC_FIREBASE_API_KEY_DEV
ARG NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN_DEV
ARG NEXT_PUBLIC_FIREBASE_PROJECT_ID_DEV
ARG NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET_DEV
ARG NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID_DEV
ARG NEXT_PUBLIC_FIREBASE_APP_ID_DEV
ARG NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID_DEV

ENV NEXT_PUBLIC_APP_ENV=$NEXT_PUBLIC_APP_ENV
ENV NEXT_PUBLIC_API_BASE_URL=$NEXT_PUBLIC_API_BASE_URL
ENV NEXT_PUBLIC_FIREBASE_API_KEY_DEV=$NEXT_PUBLIC_FIREBASE_API_KEY_DEV
ENV NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN_DEV=$NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN_DEV
ENV NEXT_PUBLIC_FIREBASE_PROJECT_ID_DEV=$NEXT_PUBLIC_FIREBASE_PROJECT_ID_DEV
ENV NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET_DEV=$NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET_DEV
ENV NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID_DEV=$NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID_DEV
ENV NEXT_PUBLIC_FIREBASE_APP_ID_DEV=$NEXT_PUBLIC_FIREBASE_APP_ID_DEV
ENV NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID_DEV=$NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID_DEV

RUN pnpm --filter @inventory-management/web build

FROM base AS runner
WORKDIR /app
ENV NODE_ENV=production
COPY --from=builder /app /app
EXPOSE 8080
CMD ["sh", "-c", "pnpm --filter @inventory-management/web exec next start --hostname 0.0.0.0 --port ${PORT:-8080}"]
