FROM maven:3.9.11-eclipse-temurin-17 AS builder
WORKDIR /app
COPY services/api-spring/pom.xml ./pom.xml
COPY services/api-spring/src ./src
RUN mvn -q -DskipTests package

FROM eclipse-temurin:17-jre
WORKDIR /app
COPY --from=builder /app/target/api-spring-0.1.0.jar /app/app.jar
EXPOSE 8080
ENTRYPOINT ["sh", "-c", "java -jar /app/app.jar --server.port=${PORT:-8080}"]
