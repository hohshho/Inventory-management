{
  "name": "inventory-management",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "npm run dev --workspace @inventory-management/web",
    "dev:api": "npm run dev --workspace @inventory-management/api",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  }
}
